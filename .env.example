# ─────────────────────────────────────────────────────────────
# CoreHR AI — Environment Variables
# Copy to `.env` for local dev, or set these in Railway's
# project "Variables" tab for production.
# ─────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────

# Postgres connection string.
# From Neon: use the POOLED connection string (host contains "-pooler").
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require

# Session signing secret. App FAILS TO START in production if missing.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# ── RECOMMENDED ───────────────────────────────────────────────

# Set to "production" on Railway.
NODE_ENV=production

# Public base URL of your deployment (used to build links in emails).
# Railway gives you one like https://your-app.up.railway.app
APP_URL=https://your-app.up.railway.app

# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# ── FEATURE-DEPENDENT (only set what you use) ─────────────────

# AI features (copilots, sentiment, insights)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Transactional email (password reset, email verification)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Billing / paid plans (Tap Payments)
TAP_SECRET_KEY=
TAP_WEBHOOK_SECRET=

# Slack integration
SLACK_API_TOKEN=

# Zoom integration
ZOOM_API_KEY=
ZOOM_API_SECRET=

# Error monitoring (Sentry)
SENTRY_DSN=
SENTRY_RELEASE=
